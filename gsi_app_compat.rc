# ============================================================
# gsi_app_compat.rc — FOURTH in chain
# ============================================================

service gsi_app_compat /system/bin/sh /system/bin/app_compat_mitigations.sh
    user root
    group root system
    oneshot
    disabled

# Chain: app_compat → forward_compat
on property:sys.gsi.app_compat_done=1
    write /dev/kmsg "GSI_COMPAT: App compat done. Starting forward compat."
    start gsi_forward_compat
