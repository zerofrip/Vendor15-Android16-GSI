# ============================================================
# gsi_survival.rc
# Vendor15 Compatibility Lifetime Extension — Init Configuration
# ============================================================
#
# Boot gate: upgrade-only enforcement and cache sanitation.
#
# Flow:
#   1. post-fs-data: run gsi_survival_check.sh
#   2. Script sets sys.gsi.boot_decision property
#   3. Init reacts via property triggers (all non-blocking)
#
# Boot safety guarantees:
#   - No seclabel (runs in init context — always available)
#   - No class membership (not part of core/main/hal)
#   - No exec blocks (all commands are native init builtins)
#   - No blocking waits on vendor services
#   - Downgrade handler does NOT stop hal class
# ============================================================

# -------------------------------------------------------
# Service: gsi_survival_gate
# Runs the upgrade/downgrade check after /data is mounted.
# -------------------------------------------------------
service gsi_survival_gate /system/bin/sh /system/bin/gsi_survival_check.sh
    user root
    group root system
    oneshot
    disabled
    # NO seclabel — runs in init's own context, which is universally
    # available across all vendor SELinux policies.
    # NO class — not part of any class start/stop group.

# -------------------------------------------------------
# Trigger: post-fs-data — start the gate check
# -------------------------------------------------------
on post-fs-data
    start gsi_survival_gate

# -------------------------------------------------------
# Trigger: DOWNGRADE — halt boot safely
# -------------------------------------------------------
on property:sys.gsi.boot_decision=downgrade
    write /dev/kmsg "GSI_SURVIVAL: FATAL: DOWNGRADE DETECTED"
    write /dev/kmsg "GSI_SURVIVAL: Flash SDK >= persist.sys.prev_sdk or wipe data."
    # Stop user-facing services only — do NOT stop hal class
    # (stopping hal can kill servicemanager and cause init loops)
    class_stop main
    class_stop late_start
    # Simple reboot — do NOT use reboot,recovery which fails
    # on vendors with broken/missing recovery partitions
    setprop sys.powerctl reboot

# -------------------------------------------------------
# Trigger: UPGRADE — informational only
# -------------------------------------------------------
on property:sys.gsi.boot_decision=upgrade
    write /dev/kmsg "GSI_SURVIVAL: Upgrade boot. Caches cleared."

# -------------------------------------------------------
# Trigger: NORMAL / FIRST BOOT — informational only
# -------------------------------------------------------
on property:sys.gsi.boot_decision=normal
    write /dev/kmsg "GSI_SURVIVAL: Normal boot."

on property:sys.gsi.boot_decision=first_boot
    write /dev/kmsg "GSI_SURVIVAL: First boot. SDK baseline recorded."

# -------------------------------------------------------
# Trigger: boot_completed — clear upgrade flag
# Uses only native init builtins. No exec/shell spawn.
# -------------------------------------------------------
on property:sys.boot_completed=1 && property:persist.sys.gsi_upgrade=1
    setprop persist.sys.gsi_upgrade 0
    write /dev/kmsg "GSI_SURVIVAL: Upgrade finalized."

on property:sys.boot_completed=1
    write /dev/kmsg "GSI_SURVIVAL: Boot complete."

# -------------------------------------------------------
# Early-init: VINTF bypass + Rescue Party suppression
# -------------------------------------------------------
on early-init
    setprop ro.vintf.enforce false
    setprop persist.sys.disable_rescue true
    write /dev/kmsg "GSI_SURVIVAL: Survival mode active (early-init)"
