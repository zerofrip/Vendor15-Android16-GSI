# gsi_compat.rc
# Init configuration for the GSI Compatibility AIDL service.
#
# Boot safety:
#   - Service is "disabled" — init does NOT start it automatically
#   - Triggered ONLY by sys.boot_completed=1 (post-boot)
#   - "oneshot" — runs once, does not restart on crash
#   - If the binary is missing or crashes, init ignores it
#   - No class membership — not part of "main", "core", or "hal"
#   - No watchdog — system_server does not depend on this
#
# This service has ZERO impact on boot success.

service gsi_compat_service /system/bin/gsi_compat_service
    user system
    group system
    disabled
    oneshot
    # No class — explicitly not boot-critical
    # SELinux: runs in its own system domain
    # Falls back safely — init ignores missing binaries

on property:sys.boot_completed=1
    start gsi_compat_service
