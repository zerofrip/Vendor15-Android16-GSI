<?xml version="1.0" encoding="UTF-8"?>
<!--
    Vendor15 Frozen Compatibility Matrix
    =====================================
    Purpose: Declares framework HAL requirements frozen at what Android 15
             (FCM level 202404) vendor partitions actually provide.

    This file REPLACES the stock framework compatibility matrix at build time
    so that newer Android system images (A16, A17, A18, ...) will pass VINTF
    compatibility checks against a frozen Vendor15 partition.

    Design rules applied:
      1. FCM level is pinned to 202404 (Android 15 era).
      2. Every HAL is marked optional="true" so that a missing HAL degrades
         the feature instead of aborting init / system_server.
      3. Version ranges start at the exact version Vendor15 provides and
         extend upward to accept any newer vendor that also satisfies the
         contract (future-proofing the matrix itself).
      4. Automotive, TV, broadcast-radio, and other niche HALs are removed
         entirely — they are never present on typical phone vendor images.
      5. Boot-critical HALs (graphics, keymint, health, gatekeeper, boot)
         remain listed so the framework still attempts to connect.

    Source of truth: compatibility_matrix.202404.xml from
        hardware/interfaces/compatibility_matrices/
        (AOSP android-16.0.0 branch, which contains A15-era FCM)

    Usage in build.sh:
        export DEVICE_FRAMEWORK_COMPATIBILITY_MATRIX_FILE=\
            "$(pwd)/compatibility_matrix_vendor15_frozen.xml"
-->
<compatibility-matrix version="1.0" type="framework" level="202404">

    <!-- ============================================================ -->
    <!-- AUDIO                                                        -->
    <!-- Vendor15 provides: audio.core AIDL v1-2                      -->
    <!-- ============================================================ -->
    <hal format="aidl" optional="true">
        <name>android.hardware.audio.core</name>
        <version>1-2</version>
        <interface>
            <name>IModule</name>
            <instance>default</instance>
            <instance>a2dp</instance>
            <instance>bluetooth</instance>
            <instance>hearing_aid</instance>
            <instance>msd</instance>
            <instance>r_submix</instance>
            <instance>stub</instance>
            <instance>usb</instance>
        </interface>
        <interface>
            <name>IConfig</name>
            <instance>default</instance>
        </interface>
    </hal>

    <hal format="aidl" optional="true">
        <name>android.hardware.audio.effect</name>
        <version>1-2</version>
        <interface>
            <name>IFactory</name>
            <instance>default</instance>
        </interface>
    </hal>

    <hal format="aidl" optional="true">
        <name>android.hardware.audio.sounddose</name>
        <version>1-3</version>
        <interface>
            <name>ISoundDoseFactory</name>
            <instance>default</instance>
        </interface>
    </hal>

