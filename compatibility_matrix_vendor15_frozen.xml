    <hal format="aidl" optional="true">
        <name>android.hardware.wifi.supplicant</name>
        <version>2-3</version>
        <interface>
            <name>ISupplicant</name>
            <instance>default</instance>
        </interface>
    </hal>

    <!-- ============================================================ -->
    <!-- NATIVE MAPPER (PASSTHROUGH HAL)                              -->
    <!-- Vendor15 provides: native mapper v5.0                        -->
    <!-- This is dlopen'd by libui — critical for graphics            -->
    <!-- ============================================================ -->
    <hal format="native" optional="true">
        <name>mapper</name>
        <version>5.0</version>
        <interface>
            <regex-instance>.*</regex-instance>
        </interface>
    </hal>

