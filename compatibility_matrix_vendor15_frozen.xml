    <!-- EXPLICITLY OMITTED HALs (not present on phone vendors)       -->
    <!-- ============================================================ -->
    <!--
        The following HALs from the stock 202404/202504/202604 matrices
        are intentionally omitted because they are either:
          (a) Not present on typical phone vendor images
          (b) Niche hardware that, if absent, causes no boot impact

        - android.hardware.automotive.*     (automotive only)
        - android.hardware.macsec           (automotive only)
        - android.hardware.broadcastradio   (automotive/radio only)
        - android.hardware.tv.*             (TV devices only)
        - android.hardware.bluetooth.socket (A16+ addition, not on V15)
