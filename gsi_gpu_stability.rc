# ============================================================
# gsi_gpu_stability.rc — SECOND in chain
# ============================================================

service gsi_gpu_stability /system/bin/sh /system/bin/gpu_stability.sh
    user root
    group root system
    oneshot
    disabled
    # NO seclabel — runs in init's own context

# Chain: gpu_stability → hal_mitigations
on property:sys.gsi.gpu_stability_done=1
    write /dev/kmsg "GSI_GPU: GPU stability done. Starting HAL mitigations."
    start gsi_hal_mitigations
