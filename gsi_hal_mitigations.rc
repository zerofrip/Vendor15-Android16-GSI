# ============================================================
# gsi_hal_mitigations.rc — THIRD in chain
# ============================================================

service gsi_hal_mitigations /system/bin/sh /system/bin/hal_gap_mitigations.sh
    user root
    group root system
    oneshot
    disabled

# Chain: hal_mitigations → app_compat
on property:sys.gsi.hal_mitigations_done=1
    write /dev/kmsg "GSI_HAL: HAL mitigations done. Starting app compat."
    start gsi_app_compat
