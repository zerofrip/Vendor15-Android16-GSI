# ============================================================
# gsi_forward_compat.rc — FIFTH in chain
# ============================================================

service gsi_forward_compat /system/bin/sh /system/bin/forward_compat.sh
    user root
    group root system
    oneshot
    disabled

# Chain: forward_compat → hal_probe
on property:sys.gsi.forward_compat_done=1
    write /dev/kmsg "GSI_FWDCOMPAT: Forward compat done. Starting HAL probing."
    start gsi_hal_probe

